{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": [
        "node_modules/**",
        ".next/**",
        "app/**",
        "components/**",
        "public/**",
        "styles/**",
        "hooks/**",
        "lib/**",
        "contexts/**"
      ]
    },
    "api/index.py": {
      "excludeFiles": [
        "node_modules/**",
        ".next/**",
        "app/**",
        "components/**",
        "public/**",
        "styles/**",
        "hooks/**",
        "lib/**",
        "contexts/**"
      ]
    }
  }
}
