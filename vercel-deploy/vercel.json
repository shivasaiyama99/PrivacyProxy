{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules,.next,public,app,components,styles,hooks,lib,contexts}/**"
    },
    "api/index.py": {
      "excludeFiles": "{node_modules,.next,public,app,components,styles,hooks,lib,contexts}/**"
    }
  }
}
