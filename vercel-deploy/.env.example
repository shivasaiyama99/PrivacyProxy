# ==============================================================================
# PrivacyProxy Unified Environment Variables (Vercel Configuration Guide)
# ==============================================================================

# --- Frontend Configuration ---
# API Base URL for frontend requests. 
# For Vercel single-deployment, set this to '/api' so it routes through vercel.json.
NEXT_PUBLIC_API_BASE=/api

# --- Backend Configuration ---
# App URL (your production Vercel domain)
APP_URL=https://your-privacy-proxy-app.vercel.app

# API Keys (Groq is the primary LLM used for auditing/assistant)
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB Atlas URL (cloud database URL)
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/database

# Authentication Secrets
JWT_SECRET_KEY=generate_a_secure_random_string_for_production
JWT_EXPIRE_HOURS=24
DEVICE_HASH_SALT=generate_another_random_string_for_device_hashing

# Geo-Fencing Configuration
# DEV_MODE: Set to false to enforce region/city access gates in production
DEV_MODE=false

# Email SMTP Settings (For Password Resets)
EMAIL_USER=your_smtp_email@gmail.com
EMAIL_PASS=your_smtp_app_password
