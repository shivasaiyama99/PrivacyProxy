# ===========================
# Root Gitignore for PrivacyProxy Monorepo
# ===========================

# Byte-compiled / optimized / DLL files (Python)
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# C extensions
*.so

# Distribution / Packaging (Python)
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
target/

# Virtual Environments (Python)
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.virtualenv/

# Dependencies (Node / Javascript)
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js / React / Build outputs
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Vercel / Netlify / Deployment
.vercel/
.netlify/

# Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env
secrets.json
secrets.yaml
secrets.toml
*.pem
*.key
*.cert

# Large Files & Databases (GitHub restricts files > 100MB, and files > 50MB are warned)
*.mmdb
GeoLite2-City.mmdb

# Logs & Audit Files
*.log
logs/
audit_log.jsonl
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing & Coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
test-results/
reports/
coverage/
.nyc_output/
playwright-report/
cypress/screenshots/
cypress/videos/

# Editor & IDE
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject
*.swp
*.swo
*~
.fleet/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# v0 Runtime Files (Next.js preview runtime)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
instrumentation-client.js
instrumentation-client.ts
